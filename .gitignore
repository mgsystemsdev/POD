node_modules/
dist/
tmp/
/.cursor/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.coverage
htmlcov/

# ── Secrets / env ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.template
!.env.*.template
credentials.json
*_token.json
*_credentials.json

