  "implementation_status": "complete",
  "summary": "SQLite-backed task_worker claims one pending task per run, loads project context via context_loader, builds prompts with claude_prompts, calls Anthropic Messages API with retries via claude_execution.run_messages_with_retry, persists assistant text to runs.agent on success (run_service), sets task done; on failure run failed + task blocked. No direct db/sqlite3 in task_worker.",
  "architecture": {
    "worker_entry": "system/services/task_worker.py",
    "boundary_modules": [
      "task_service",
      "run_service",
      "context_loader",
      "claude_prompts",
      "claude_execution"
    ],
    "forbidden_in_worker": ["sqlite3", "db.connect", "direct SQL"],
    "invariants": [
      "At most one task claimed per process (claim_next_pending)",
      "Run lifecycle: pending → running → success|failed",
      "Success output serialized into runs.agent via run_service.update_run(..., output=...)"
    ]
  },
  "dependencies": {
