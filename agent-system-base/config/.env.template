# agent-services environment configuration
# Copy this file to ~/agent-services/.env and fill in the values.
# NEVER commit .env to version control.

# ── Required: Anthropic API ────────────────────────────────────────────────────
# Required for orchestrator execute mode and task worker claude_execute tasks.
ANTHROPIC_API_KEY=

# Model to use for autonomous execution (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max tokens per API call (default: 8192)
ANTHROPIC_MAX_TOKENS=8192

# ── Required: Exa Search API ──────────────────────────────────────────────────
# Required for the exa skill (deep web search, company research, people lookup).
# Get key at: https://exa.ai
EXA_API_KEY=

# ── Required: Gmail Integration ───────────────────────────────────────────────
# Required for the gmail_triage worker.
# Path to OAuth2 credentials JSON file (from Google Cloud Console).
GMAIL_CREDENTIALS_PATH=

# Path to Gmail OAuth token cache (auto-generated on first auth).
GMAIL_TOKEN_PATH=~/agent-services/state/gmail_token.json

# ── Optional: Dashboard ───────────────────────────────────────────────────────
# Port for the task dashboard (default: 8765)
DASHBOARD_PORT=8765
