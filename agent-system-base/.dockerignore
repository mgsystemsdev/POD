# Ignore git and local caches
.git/
.cursor/
.ruff_cache/
.pytest_cache/
.mypy_cache/
__pycache__/
*.pyc
*.pyo

# Ignore local state and logs
logs/
runs/
state/
system/db/*.sqlite*

# Ignore frontend source and heavy deps (using pre-built dist if present)
node_modules/
system/dashboard/ui/node_modules/
system/dashboard/ui/src/
